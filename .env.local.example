# ── Supabase ──────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Anthropic (optional — AI task breakdown + insights) ───
# Get from: https://console.anthropic.com
# If omitted, the app works without AI features.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Set to "true" when ANTHROPIC_API_KEY is present — tells the client to show AI features
NEXT_PUBLIC_AI_ENABLED=true

# ── Email nudges via Resend (optional) ────────────────────
# Get from: https://resend.com (free: 3,000 emails/month)
RESEND_API_KEY=re_your-key-here
EMAIL_FROM=Channel <nudge@yourdomain.com>

# ── Cron job security ─────────────────────────────────────
# Any random string — add this to Vercel env vars too
CRON_SECRET=your-random-secret-here

# ── Supabase service role (for cron email fan-out) ────────
# Settings → API → service_role key (NEVER expose in browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
